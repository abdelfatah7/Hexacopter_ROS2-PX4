    <!-- ╔═══════════════════════════════════════════════════════════════╗
         ║  ZONE 1 — WP4/WP5/WP6  (FAR EAST)                            ║
         ║  Center: (11.021, -1.598)                                    ║
         ║  Drone approaches from WEST → fighters face NORTH-SOUTH      ║
         ║  Attacker lunges SOUTH toward defender, defender recoils     ║
         ╚═══════════════════════════════════════════════════════════════╝ -->
    <actor name="attacker_zone1">
      <skin><filename>/home/abdelfattah/Downloads/Boxing.dae</filename><scale>0.01</scale></skin>
      <animation name="boxing"><filename>/home/abdelfattah/Downloads/Boxing.dae</filename><scale>0.01</scale></animation>
      <script>
        <loop>true</loop><delay_start>0.0</delay_start><auto_start>true</auto_start>
        <trajectory id="0" type="boxing">
          <!-- Start position -->
          <waypoint><time>0.0</time>  <pose>11.021  0.20 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Lunge forward (toward defender) at t=0.8s -->
          <waypoint><time>0.8</time>  <pose>11.021 -0.15 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Hold for impact -->
          <waypoint><time>1.2</time>  <pose>11.021 -0.15 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Reset back -->
          <waypoint><time>2.0</time>  <pose>11.021  0.20 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Brief pause -->
          <waypoint><time>2.5</time>  <pose>11.021  0.20 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Second lunge (faster) -->
          <waypoint><time>3.0</time>  <pose>11.021 -0.20 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Hold -->
          <waypoint><time>3.4</time>  <pose>11.021 -0.20 0.85 1.57 0  0.00</pose></waypoint>
          <!-- Reset -->
          <waypoint><time>4.0</time>  <pose>11.021  0.20 0.85 1.57 0  0.00</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <actor name="defender_zone1">
      <skin><filename>/home/abdelfattah/Downloads/Outward_Block.dae</filename><scale>0.01</scale></skin>
      <animation name="blocking"><filename>/home/abdelfattah/Downloads/Outward_Block.dae</filename><scale>0.01</scale></animation>
      <script>
        <loop>true</loop><delay_start>0.0</delay_start><auto_start>true</auto_start>
        <trajectory id="0" type="blocking">
          <!-- Start position -->
          <waypoint><time>0.0</time>  <pose>11.021 -0.70 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Recoil back (away from attacker) at t=0.8s -->
          <waypoint><time>0.8</time>  <pose>11.021 -1.05 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Hold -->
          <waypoint><time>1.2</time>  <pose>11.021 -1.05 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Reset forward -->
          <waypoint><time>2.0</time>  <pose>11.021 -0.70 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Brief pause -->
          <waypoint><time>2.5</time>  <pose>11.021 -0.70 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Second recoil -->
          <waypoint><time>3.0</time>  <pose>11.021 -1.10 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Hold -->
          <waypoint><time>3.4</time>  <pose>11.021 -1.10 0.85 1.57 0  3.14</pose></waypoint>
          <!-- Reset -->
          <waypoint><time>4.0</time>  <pose>11.021 -0.70 0.85 1.57 0  3.14</pose></waypoint>
        </trajectory>
      </script>
